<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Document</title>
</head>
<body>
    <% for (let chat of Chats) { %>
        <div>
            <p>From: <%= chat.from %></p>
            <p>To: <%= chat.to %></p>
            <p>Message: <%= chat.msg %></p>
        </div>
    <% } %>
</body>
</html>
